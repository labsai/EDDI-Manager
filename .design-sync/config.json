{
  "pkg": "eddi-manager",
  "globalName": "EDDI",
  "projectId": "408b967f-5a31-4a9f-85f7-f8794639218b",
  "shape": "package",
  "entry": ".design-sync/ds-entry.tsx",
  "tsconfig": "tsconfig.app.json",
  "buildCmd": "node .design-sync/build-css.mjs",
  "cssEntry": ".design-sync/.cache/compiled.css",
  "extraFonts": ["node_modules/@fontsource-variable/noto-sans/index.css"],
  "readmeHeader": ".design-sync/conventions.md",
  "provider": { "component": "DesignSyncProvider" },
  "overrides": {
    "AccessibleDialog": { "cardMode": "single", "viewport": "560x560" },
    "AlertDialog": { "cardMode": "single", "viewport": "560x440" },
    "UnsavedChangesDialog": { "cardMode": "single", "viewport": "520x480" },
    "CreateOrWizardDialog": { "cardMode": "single", "viewport": "760x620" },
    "AgentPicker": { "cardMode": "column" },
    "SecretKeyPicker": { "cardMode": "column" }
  },
  "componentSrcMap": {
    "AccessibleDialog": "src/components/ui/accessible-dialog.tsx",
    "AlertDialog": "src/components/ui/alert-dialog.tsx",
    "Badge": "src/components/ui/badge.tsx",
    "Button": "src/components/ui/button.tsx",
    "Card": "src/components/ui/card.tsx",
    "ErrorBoundary": "src/components/ui/error-boundary.tsx",
    "Input": "src/components/ui/input.tsx",
    "Skeleton": "src/components/ui/skeleton.tsx",
    "StreamBadge": "src/components/ui/stream-badge.tsx",
    "UnsavedChangesDialog": "src/components/ui/unsaved-changes-dialog.tsx",
    "ActionBadge": "src/components/shared/action-badge.tsx",
    "AgentPicker": "src/components/shared/agent-picker.tsx",
    "BackLink": "src/components/shared/back-link.tsx",
    "CommandPalette": "src/components/shared/command-palette.tsx",
    "CreateOrWizardDialog": "src/components/shared/create-or-wizard-dialog.tsx",
    "EmptyState": "src/components/shared/empty-state.tsx",
    "ErrorState": "src/components/shared/error-state.tsx",
    "InfiniteScrollSentinel": "src/components/shared/infinite-scroll-sentinel.tsx",
    "ResourceTypeBadge": "src/components/shared/resource-type-badge.tsx",
    "SecretKeyPicker": "src/components/shared/secret-key-picker.tsx",
    "ViewToggle": "src/components/shared/view-toggle.tsx"
  }
}
