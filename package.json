{
  "name": "eddi-config-ui",
  "version": "1.0.0-RC",
  "description": "eddi-config-ui",
  "main": "index.js",
  "scripts": {
    "server": "node server.js --path ./dist --port 3000 --env \"{\\\"EDDI_API_URL\\\":\\\"$EDDI_API_URL\\\", \\\"AUTH_METHOD\\\":\\\"$AUTH_METHOD\\\", \\\"AUTH_REALM\\\":\\\"$AUTH_REALM\\\", \\\"AUTH_URL\\\":\\\"$AUTH_URL\\\", \\\"AUTH_CLIENT_ID\\\":\\\"$AUTH_CLIENT_ID\\\", \\\"READ_ONLY_DOMAIN\\\":\\\"$READ_ONLY_DOMAIN\\\"}\"",
    "autoformat": "prettier --write '**/*.{ts,tsx,js,jsx,json,css,scss}'",
    "start": "cross-env PORT=1338 NODE_ENV=local \"(echo $PORT && npm run open-browser & webpack-dev-server)\"",
    "open-browser": "wait-on --timeout 8000 tcp:$PORT && open-url localhost:$PORT",
    "clean": "rimraf \"src/**/*.+(js|js.map)\" \"tests/unit/tests/**/*.+(js|js.map)\" \"compiled\" \"dist\"",
    "clean-coverage": "rimraf \".nyc_output\" \"coverage\"",
    "compile-ts": "npm run clean && tsc -p tsconfig.test.json",
    "prepush": "npm run test",
    "pretest": "rimraf compiled && tsc -p tsconfig.test.json",
    "posttest": "npm run lint && npm run check-circular-dependencies",
    "lint-staged": "lint-staged",
    "code-coverage": "npm run clean-coverage && nyc npm test",
    "code-coverage-report": "npm run code-coverage && nyc report --reporter=text-lcov",
    "check-circular-dependencies": "npm run compile-ts && madge --circular compiled/",
    "lint": "tslint -c tslint.json \"src/{**,}/*.ts*\" \"tests/{**,}/*.ts*\"",
    "test": "mocha \"compiled/tests/unit/**/*.js\" \"compiled/src/**/*.spec.js\"",
    "build": "npm run clean && webpack",
    "serve-build": "node server.js --path ./dist",
    "serve-local": "NODE_ENV=local npm run build && node server.js --path ./dist",
    "serve-production": "NODE_ENV=production npm run build && node server.js --path ./dist"
  },
  "docker": {
    "imageUrl": "labsai/eddi-config-ui"
  },
  "nyc": {
    "check-coverage": true,
    "lines": 70,
    "exclude": [
      "**/*.spec.*",
      "test",
      "test{,-*}.js",
      "**/*.test.js",
      "**/__tests__/**",
      "**/node_modules/**",
      "typings"
    ],
    "extension": [
      ".ts",
      ".tsx"
    ],
    "require": [
      "ts-node/register"
    ]
  },
  "pre-commit": [
    "lint-staged"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,scss}": [
      "prettier --write",
      "git add"
    ]
  },
  "devDependencies": {
    "@types/chai": "3.5.2",
    "@types/enzyme": "2.8.12",
    "@types/immutability-helper": "2.6.3",
    "@types/lodash": "4.14.66",
    "@types/mocha": "2.2.41",
    "@types/radium": "0.18.23",
    "@types/react": "16.0.34",
    "@types/react-dom": "16.0.3",
    "@types/react-redux": "4.4.47",
    "awesome-typescript-loader": "3.4.1",
    "babel-core": "6.26.0",
    "babel-loader": "7.1.2",
    "babel-plugin-transform-es2015-modules-commonjs": "6.26.0",
    "babel-polyfill": "6.26.0",
    "babel-preset-es2015": "6.24.1",
    "babel-preset-es2016": "6.24.1",
    "babel-preset-react": "6.24.1",
    "babel-preset-stage-0": "6.24.1",
    "babel-register": "6.26.0",
    "chai": "4.0.0",
    "copy-webpack-plugin": "4.0.1",
    "coveralls": "2.11.9",
    "cross-env": "4.0.0",
    "css-loader": "0.28.0",
    "enzyme": "3.0.0",
    "enzyme-adapter-react-15": "1.0.0",
    "extract-text-webpack-plugin": "2.1.0",
    "file-loader": "0.11.1",
    "generate-json-webpack-plugin": "0.2.2",
    "html-webpack-plugin": "2.28.0",
    "husky": "0.13.3",
    "istanbul-instrumenter-loader": "2.0.0",
    "jsdom": "9.12.0",
    "jsdom-global": "2.1.1",
    "lint-staged": "6.1.0",
    "madge": "1.6.0",
    "mocha": "3.5.3",
    "mockery": "2.1.0",
    "node-sass": "4.7.2",
    "nyc": "10.3.2",
    "open-url": "2.0.2",
    "pre-commit": "1.2.2",
    "prettier": "1.10.2",
    "react-addons-perf": "15.4.2",
    "react-hot-loader": "1.3.1",
    "react-test-renderer": "15.6.2",
    "rimraf": "2.6.2",
    "sass-loader": "6.0.6",
    "source-map-loader": "0.2.3",
    "style-loader": "0.17.0",
    "ts-node": "3.3.0",
    "tslib": "1.8.1",
    "tslint": "5.1.0",
    "tslint-loader": "3.5.3",
    "typescript": "2.3.4",
    "typescript-formatter": "5.2.0",
    "uglify-js": "2.8.29",
    "uglifyjs-webpack-plugin": "0.4.6",
    "url-loader": "0.5.9",
    "wait-on": "2.1.0",
