{
  "name": "eddi-manager",
  "version": "1.0.0-RC",
  "description": "eddi-manager",
  "main": "index.js",
  "scripts": {
    "server": "node server.js --path ./dist --port 3000 --env \"{\\\"EDDI_API_URL\\\":\\\"$EDDI_API_URL\\\", \\\"AUTH_METHOD\\\":\\\"$AUTH_METHOD\\\", \\\"AUTH_REALM\\\":\\\"$AUTH_REALM\\\", \\\"AUTH_URL\\\":\\\"$AUTH_URL\\\", \\\"AUTH_CLIENT_ID\\\":\\\"$AUTH_CLIENT_ID\\\", \\\"READ_ONLY_DOMAIN\\\":\\\"$READ_ONLY_DOMAIN\\\"}\"",
    "autoformat": "prettier --write '**/*.{ts,tsx,js,jsx,json,css,scss}'",
    "start": "cross-env-shell PORT=1338 NODE_ENV=local \"(echo $PORT && webpack serve --mode development --open)\"",
    "open-browser": "wait-on --timeout 8000 tcp:$PORT && open-url localhost:$PORT",
    "clean": "rimraf \"src/**/*.+(js|js.map)\" \"tests/unit/tests/**/*.+(js|js.map)\" \"compiled\" \"dist\"",
    "clean-coverage": "rimraf \".nyc_output\" \"coverage\"",
    "compile-ts": "npm run clean && tsc -p tsconfig.test.json",
    "prepush": "npm run test",
    "pretest": "rimraf compiled && tsc -p tsconfig.test.json",
    "posttest": "npm run lint && npm run check-circular-dependencies",
    "lint-staged": "lint-staged",
    "code-coverage": "npm run clean-coverage && nyc npm test",
    "code-coverage-report": "npm run code-coverage && nyc report --reporter=text-lcov",
    "check-circular-dependencies": "npm run compile-ts && madge --circular compiled/",
    "lint": "tslint -c tslint.json \"src/{**,}/*.ts*\" \"tests/{**,}/*.ts*\"",
    "test": "mocha \"compiled/tests/unit/**/*.js\" \"compiled/src/**/*.spec.js\"",
    "build": "npm run clean && webpack",
    "serve-build": "node server.js --path ./dist",
    "serve-local": "NODE_ENV=local npm run build && node server.js --path ./dist",
    "serve-production": "NODE_ENV=production npm run build && node server.js --path ./dist"
  },
  "docker": {
    "imageUrl": "labsai/eddi-manager"
  },
  "nyc": {
    "check-coverage": true,
    "lines": 70,
    "exclude": [
      "**/*.spec.*",
      "test",
      "test{,-*}.js",
      "**/*.test.js",
      "**/__tests__/**",
      "**/node_modules/**",
      "typings"
    ],
    "extension": [
      ".ts",
      ".tsx"
    ],
    "require": [
      "ts-node/register"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,scss}": [
      "prettier --write",
      "git add"
    ]
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@babel/preset-typescript": "^7.24.7",
    "@babel/runtime": "7.24.7",
    "@types/ace": "^0.0.52",
    "@types/chai": "4.3.16",
    "@types/enzyme": "3.10.18",
    "@types/immutability-helper": "2.6.3",
    "@types/json-schema": "^7.0.3",
    "@types/lodash": "^4.14.170",
    "@types/mocha": "10.0.6",
    "@types/moment": "^2.13.0",
    "@types/radium": "^0.24.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/react-redux": "7.1.33",
    "@types/react-router-dom": "^5.1.7",
    "@types/recompose": "^0.30.7",
    "awesome-typescript-loader": "5.2.1",
    "babel-core": "^7.0.0-bridge.0",
    "babel-loader": "9.1.3",
    "babel-plugin-transform-es2015-modules-commonjs": "6.26.2",
    "babel-polyfill": "^6.26.0",
    "babel-preset-es2015": "^6.24.1",
    "babel-preset-stage-0": "^6.24.1",
    "chai": "5.1.1",
    "copy-webpack-plugin": "12.0.2",
    "coveralls": "^3.0.7",
    "cross-env": "7.0.3",
    "css-loader": "^7.1.2",
    "enzyme": "^3.0.0",
    "enzyme-adapter-react-16": "^1.15.1",
    "file-loader": "6.2.0",
    "generate-json-webpack-plugin": "2.0.0",
    "html-webpack-plugin": "5.6.0",
    "husky": "9.0.11",
    "lint-staged": "15.2.5",
    "madge": "^7.0.0",
    "mocha": "^10.4.0",
    "mockery": "2.1.0",
    "nyc": "^15.1.0",
    "open-url": "2.0.2",
    "pre-commit": "1.2.2",
    "prettier": "3.3.1",
    "react-addons-perf": "15.4.2",
    "react-hot-loader": "4.13.1",
    "react-test-renderer": "18.3.1",
    "rimraf": "5.0.7",
    "sass-loader": "14.2.1",
    "source-map-loader": "5.0.0",
    "style-loader": "4.0.0",
    "ts-node": "10.9.2",
    "tslib": "^2.2.0",
    "tslint": "6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "tslint-loader": "3.5.4",
    "typescript": "5.4.5",
    "typescript-formatter": "7.2.2",
    "uglify-js": "3.17.4",
    "uglifyjs-webpack-plugin": "2.2.0",
    "url-loader": "^4.1.1",
    "wait-on": "7.2.0",
    "webpack": "^5.39.1",
    "webpack-cli": "^4.7.0",
    "webpack-dev-server": "^3.11.2"
  },
  "dependencies": {
    "@babel/core": "^7.24.7",
    "@babel/register": "^7.13.16",
    "@emotion/react": "^11.10.8",
    "@emotion/styled": "^11.10.8",
    "@fortawesome/fontawesome-svg-core": "^6.5.2",
    "@fortawesome/free-solid-svg-icons": "^6.5.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@material-ui/core": "^4.12.4",
    "@material-ui/icons": "^4.11.3",
    "@types/keycloak-js": "^3.4.1",
    "ace-builds": "^1.4.7",
    "ajv": "6",
    "axios": "^1.7.2",
    "babel-register": "^6.26.0",
    "cors": "^2.8.5",
