    "prop-types": "15.8.1",
    "radium": "0.26.2",
    "react": "^18.3.1",
    "react-ace": "^11.0.1",
    "react-beautiful-dnd": "^13.1.0",
    "react-dom": "^18.3.1",
    "react-hook-consent": "^3.2.0",
    "react-infinite-scroller": "^1.2.4",
    "react-json-view": "^1.19.1",
    "react-jsonschema-form": "^1.8.0",
    "react-markdown": "^9.0.1",
    "react-redux": "^9.1.2",
    "react-router": "^6.23.1",
    "react-router-dom": "^6.23.1",
    "react-slick": "^0.30.2",
    "react-spinners": "^0.13.8",
    "recompose": "0.30.0",
    "redux": "5.0.1",
    "redux-persist": "^6.0.0",
    "redux-saga": "1.3.0",
    "rehype-highlight": "^7.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "render-if": "^0.1.1",
    "reselect": "5.1.1",
    "route-parser": "0.0.5",
    "serve-static": "1.15.0",
    "slick-carousel": "^1.8.1"
  }
}
