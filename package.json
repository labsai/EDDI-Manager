    "react-select": "^2.4.4",
    "react-spinners": "0.2.6",
    "recompose": "0.26.0",
    "redux": "3.6.0",
    "redux-saga": "0.16.0",
    "render-if": "0.1.1",
    "reselect": "3.0.1",
    "route-parser": "0.0.5",
    "semantic-ui-react": "^0.81.3",
    "serve-static": "1.13.2"
  }
}
