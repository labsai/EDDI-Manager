    "webpack-dev-server": "^2.11.5"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.2.25",
    "@fortawesome/free-solid-svg-icons": "^5.11.2",
    "@fortawesome/react-fontawesome": "^0.1.6",
    "@types/ace": "0.0.42",
    "@types/json-schema": "^7.0.3",
    "ajv": "^6.10.2",
    "axios": "0.17.1",
    "cors": "^2.8.5",
    "express": "4.16.2",
    "express-session": "^1.17.0",
    "immutability-helper": "2.2.0",
    "json-schema-migrate": "^0.2.0",
    "json-source-map": "^0.4.0",
    "keycloak-js": "^5.0.0",
    "lodash": "4.13.1",
    "minimist": "1.2.0",
    "moment": "2.18.1",
    "npm": "^6.12.0",
    "prop-types": "15.6.0",
    "radium": "0.21.1",
    "react": "^16.10.2",
    "react-ace": "^6.6.0",
    "react-dom": "^16.10.2",
    "react-infinite-scroller": "^1.2.4",
    "react-json-view": "^1.19.1",
    "react-modal": "^3.10.1",
    "react-native-web-image-loader": "0.0.5",
    "react-redux": "5.0.4",
    "react-router": "4.2.0",
