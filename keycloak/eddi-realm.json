{
  "realm": "eddi",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full administrative access to EDDI Manager"
      },
      {
        "name": "editor",
        "description": "Can create, edit, and delete bots, packages, and extensions"
      },
      {
        "name": "viewer",
        "description": "Read-only access to EDDI Manager"
      }
    ]
  },
  "clients": [
    {
      "clientId": "eddi-manager",
      "name": "EDDI Manager",
      "description": "EDDI Manager admin dashboard",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost:5173",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:7071/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:7071"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "eddi",
      "email": "eddi@labs.ai",
      "firstName": "EDDI",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "eddi",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "default-roles-eddi"
      ]
    },
    {
      "username": "viewer",
      "email": "viewer@labs.ai",
      "firstName": "EDDI",
      "lastName": "Viewer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "viewer",
          "temporary": false
        }
      ],
      "realmRoles": [
        "viewer",
        "default-roles-eddi"
      ]
    }
  ]
}
