  securitySchemes:
    Keycloak OIDC:
      description: OAuth2 / OpenID Connect via Keycloak. Only enforced when QUARKUS_OIDC_TENANT_ENABLED=true.
      type: openIdConnect
      openIdConnectUrl: http://localhost:8180/realms/eddi/.well-known/openid-configuration
paths:
  /.well-known/agent.json:
    get:
      operationId: getDefaultAgentCard
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema: {}
      summary: Get Default Agent Card
      tags:
      - Rest A 2 A Endpoint
  /AgentTriggerStore/agenttriggers:
    get:
      operationId: readAllAgentTriggers
      tags:
      - Agent Administration
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/AgentTriggerConfiguration"
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
        - eddi-editor
    post:
      operationId: createAgentTrigger
      tags:
      - Agent Administration
      requestBody:
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/AgentTriggerConfiguration"
        required: true
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema: {}
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
        - eddi-editor
  /AgentTriggerStore/agenttriggers/{intent}:
    put:
      operationId: updateAgentTrigger
      tags:
      - Agent Administration
      parameters:
      - name: intent
        in: path
        required: true
        schema:
          type: string
      requestBody:
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/AgentTriggerConfiguration"
        required: true
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema: {}
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
        - eddi-editor
    get:
      operationId: readAgentTrigger
      tags:
      - Agent Administration
      parameters:
      - name: intent
        in: path
        required: true
        schema:
          type: string
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/AgentTriggerConfiguration"
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
        - eddi-editor
    delete:
      operationId: deleteAgentTrigger
      tags:
      - Agent Administration
      parameters:
      - name: intent
        in: path
        required: true
        schema:
          type: string
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema: {}
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
        - eddi-editor
  /a2a/agents:
    get:
      operationId: listA2AAgents
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema: {}
      summary: List A 2 A Agents
      tags:
      - Rest A 2 A Endpoint
  /a2a/agents/{agentId}:
    post:
      operationId: handleJsonRpc
      parameters:
      - name: agentId
        in: path
        required: true
        schema:
          type: string
      requestBody:
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/JsonRpcRequest"
        required: true
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema: {}
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
        "400":
          description: Bad Request
      summary: Handle Json Rpc
      tags:
      - Rest A 2 A Endpoint
      security:
      - Keycloak OIDC: []
