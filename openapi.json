  /admin/gdpr/{userId}:
    delete:
      summary: Cascade-delete all user data (GDPR Art. 17)
      description: Deletes user memories and conversations. Pseudonymizes audit ledger
        and database log entries. Returns a summary of affected records.
      operationId: deleteUserDataGdpr
      tags:
      - GDPR / Privacy
      parameters:
      - description: User ID to erase
        required: true
        name: userId
        in: path
        schema:
          type: string
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/GdprDeletionResult"
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
  /admin/gdpr/{userId}/export:
    get:
      summary: Export all user data (GDPR Art. 15/20)
      description: "Returns all data associated with a user, including memories, conversations,\
        \ managed conversation mappings, and audit processing records."
      operationId: exportUserDataGdpr
      tags:
      - GDPR / Privacy
      parameters:
      - description: User ID to export
        required: true
        name: userId
        in: path
        schema:
          type: string
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/UserDataExport"
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
  /admin/gdpr/{userId}/restrict:
    delete:
      summary: Remove processing restriction (GDPR Art. 18)
      description: Restores normal conversation processing for a user.
      operationId: unrestrictProcessingGdpr
      tags:
      - GDPR / Privacy
      parameters:
      - description: User ID to unrestrict
        required: true
        name: userId
        in: path
        schema:
          type: string
      responses:
        "204":
          description: No Content
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
    post:
      summary: Restrict processing for a user (GDPR Art. 18)
      description: Stops new conversation processing while preserving all user data.
        Use when a user disputes data accuracy or objects to processing.
      operationId: restrictProcessingGdpr
      tags:
      - GDPR / Privacy
      parameters:
      - description: User ID to restrict
        required: true
        name: userId
        in: path
        schema:
          type: string
      responses:
        "201":
          description: Created
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
    get:
      summary: Check processing restriction status
      description: Returns true if processing is currently restricted for this user.
      operationId: checkProcessingRestrictionGdpr
      tags:
      - GDPR / Privacy
      parameters:
      - description: User ID to check
        required: true
        name: userId
        in: path
        schema:
          type: string
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                type: boolean
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
