      description: Creates a new conversation for the specified agent in the given
        environment. Returns 201 with Location header pointing to the new conversation.
      operationId: startConversation
      tags:
      - Conversations
      parameters:
      - name: agentId
        in: path
        required: true
        schema:
          type: string
      - description: Deployment environment.
        name: environment
        in: query
        schema:
          allOf:
          - $ref: "#/components/schemas/Environment"
          - default: production
      - description: Optional user identifier.
        name: userId
        in: query
        schema:
          type: string
      requestBody:
        content:
          application/json:
            schema:
              type: object
              additionalProperties:
                $ref: "#/components/schemas/Context"
        required: true
      responses:
        "201":
          description: Conversation created. See Location header.
  /agents/{conversationId}:
    post:
      summary: Send a message to the agent
      description: Send a plain text message and receive the agent's response.
      operationId: say
      tags:
      - Conversations
      parameters:
      - name: conversationId
        in: path
        required: true
        schema:
          type: string
      - name: returnCurrentStepOnly
        in: query
        schema:
          type: boolean
          default: "true"
      - name: returnDetailed
        in: query
        schema:
          type: boolean
          default: "false"
      - name: returningFields
        in: query
        schema:
          type: array
          items:
            type: string
      requestBody:
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/InputData"
        required: true
      responses:
        "201":
          description: Created
    get:
      summary: Read a conversation
      description: Returns conversation memory snapshot with configurable detail level.
      operationId: readConversation
      tags:
      - Conversations
      parameters:
      - name: conversationId
        in: path
        required: true
        schema:
          type: string
      - description: Only return the current (latest) step.
        name: returnCurrentStepOnly
        in: query
        schema:
          type: boolean
          default: "true"
      - description: Include detailed step data.
        name: returnDetailed
        in: query
        schema:
          type: boolean
          default: "false"
      - description: Filter fields to return.
        name: returningFields
        in: query
        schema:
          type: array
          items:
            type: string
      responses:
        "200":
          description: Conversation snapshot.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/SimpleConversationMemorySnapshot"
        "404":
          description: Conversation not found.
