    delete:
      summary: Delete package
      description: "Delete a workflow configuration. When cascade=true, also deletes\
        \ extension resources referenced by this package: behavior sets, HTTP calls,\
        \ output sets, LLM configs, property setters, and parser dictionaries. Shared\
        \ resources (used by other packages) are skipped. Partial failures are logged\
        \ but do not prevent the workflow from being deleted."
      operationId: deleteWorkflow
      tags:
      - Workflows
      parameters:
      - name: id
        in: path
        required: true
        schema:
          type: string
      - description: "If true, also delete all extension resources referenced by this\
          \ package (behavior, httpcalls, output, langchain, propertysetter, parser\
          \ dictionaries)."
        name: cascade
        in: query
        schema:
          type: boolean
          default: "false"
      - description: "If true, permanently remove from database. If false (default),\
          \ soft-delete only."
        name: permanent
        in: query
        schema:
          type: boolean
          default: "false"
      - description: Version of the workflow to delete.
        example: 1
        name: version
        required: true
        in: query
        schema:
          type: integer
          format: int32
      responses:
        "200":
          description: Workflow deleted successfully.
          content:
            application/json:
              schema: {}
        "404":
          description: Workflow not found.
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
        - eddi-editor
