  /administration/orphans:
    get:
      summary: Scan for orphaned resources
      description: "Scans all stores (packages, behavior sets, HTTP calls, output\
        \ sets, langchains, property setters, dictionaries) and returns resources\
        \ not referenced by any Agent or package. Use includeDeleted=true to also\
        \ include soft-deleted resources in the report."
      operationId: scanOrphans
      tags:
      - Orphan Admin
      parameters:
      - description: "Include soft-deleted resources in the scan. Default: false."
        name: includeDeleted
        in: query
        schema:
          type: boolean
          default: "false"
      responses:
        "200":
          description: Orphan report with list of unreferenced resources.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/OrphanReport"
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
    delete:
      summary: Purge orphaned resources
      description: Scans all stores for orphans and permanently deletes them. Returns
        a report of what was deleted. This operation is irreversible.
      operationId: purgeOrphans
      tags:
      - Orphan Admin
      parameters:
      - description: "Include soft-deleted resources in the purge. Default: true."
        name: includeDeleted
        in: query
        schema:
          type: boolean
          default: "true"
      responses:
        "200":
          description: Purge report with count and list of deleted resources.
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/OrphanReport"
        "401":
          description: Not Authorized
        "403":
          description: Not Allowed
      security:
      - Keycloak OIDC:
        - eddi-admin
