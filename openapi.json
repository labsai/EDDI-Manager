---
openapi: 3.1.0
tags:
- name: Backup
- name: Orphan Admin
- name: Agents
- name: 06. Capability Registry
  description: A2A agent capability discovery
- name: API Calls
- name: Agent Administration
- name: Descriptors
- name: Dictionary
- name: Agent Groups
- name: LLM Configuration
- name: MCP Calls
- name: Output
- name: Standalone NLP
- name: Properties
- name: User Memory
  description: Persistent user memory management
- name: RAG Ingestion
- name: RAG Knowledge Bases
- name: Behavior Rules
- name: Prompt Snippets
- name: Workflows
- name: Conversations
- name: Agent Setup
- name: Coordinator Admin
- name: Group Conversations
- name: Log Admin
- name: Audit Trail
- name: GDPR / Privacy
- name: Conversation Store
- name: Attachments
- name: Schedules
- name: Tenant Quotas
- name: Template Preview
- name: Secrets Vault
- name: Chat UI
components:
  schemas:
    A2AAgentConfig:
      type: object
      properties:
        url:
          type: string
        name:
          type: string
        skillsFilter:
          type: array
          items:
            type: string
        apiKey:
          type: string
        timeoutMs:
          type: integer
          format: int64
    AgentConfiguration:
      type: object
      properties:
        workflows:
          type: array
          items:
            type: string
            format: uri
        channels:
          type: array
          items:
            $ref: "#/components/schemas/ChannelConnector"
        a2aEnabled:
          type: boolean
        a2aSkills:
          type: array
          items:
            type: string
        capabilities:
          type: array
          items:
            $ref: "#/components/schemas/Capability"
        description:
          type: string
        identity:
          $ref: "#/components/schemas/AgentIdentity"
        security:
          $ref: "#/components/schemas/SecurityConfig"
        memoryPolicy:
          $ref: "#/components/schemas/MemoryPolicy"
        enableMemoryTools:
          type: boolean
        userMemoryConfig:
          $ref: "#/components/schemas/UserMemoryConfig"
    AgentDeployment:
      type: object
      properties:
        environment:
          $ref: "#/components/schemas/Environment"
        agentId:
          type: string
        initialContext:
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Context"
    AgentDeploymentStatus:
      type: object
      properties:
        environment:
          $ref: "#/components/schemas/Environment"
        agentId:
          type: string
        agentVersion:
          type: integer
          format: int32
        status:
          $ref: "#/components/schemas/Status"
        descriptor:
          $ref: "#/components/schemas/DocumentDescriptor"
    AgentGroupConfiguration:
      type: object
      properties:
        name:
          type: string
        description:
          type: string
        members:
          type: array
          items:
            $ref: "#/components/schemas/GroupMember"
        moderatorAgentId:
          type: string
        style:
          $ref: "#/components/schemas/DiscussionStyle"
        maxRounds:
          type: integer
          format: int32
        phases:
          type: array
          items:
            $ref: "#/components/schemas/DiscussionPhase"
        protocol:
          $ref: "#/components/schemas/ProtocolConfig"
    AgentIdentity:
      type: object
      properties:
        agentDid:
          type: string
        publicKey:
          type: string
    AgentTriggerConfiguration:
      type: object
      properties:
        intent:
          type: string
        agentDeployments:
          type: array
          items:
            $ref: "#/components/schemas/AgentDeployment"
    ApiCall:
      type: object
      properties:
        name:
          type: string
        description:
          type: string
        parameters:
          type: object
          additionalProperties:
            type: string
        actions:
          type: array
          items:
            type: string
        saveResponse:
          type: boolean
        responseObjectName:
          type: string
        responseHeaderObjectName:
          type: string
        fireAndForget:
          type: boolean
        isBatchCalls:
          type: boolean
        iterationObjectName:
          type: string
        preRequest:
          $ref: "#/components/schemas/HttpPreRequest"
        request:
          $ref: "#/components/schemas/Request"
        postResponse:
          $ref: "#/components/schemas/HttpPostResponse"
    ApiCallsConfiguration:
      type: object
      properties:
        targetServerUrl:
          type: string
        httpCalls:
          type: array
          items:
            $ref: "#/components/schemas/ApiCall"
    AuditEntry:
      type: object
      properties:
        id:
          type: string
        conversationId:
          type: string
        agentId:
          type: string
        agentVersion:
          type: integer
          format: int32
        userId:
          type: string
        environment:
          type: string
        stepIndex:
          type: integer
          format: int32
        taskId:
          type: string
        taskType:
          type: string
        taskIndex:
          type: integer
          format: int32
        durationMs:
          type: integer
          format: int64
        input:
          type: object
          additionalProperties: {}
        output:
          type: object
          additionalProperties: {}
        llmDetail:
          type: object
          additionalProperties: {}
        toolCalls:
          type: object
          additionalProperties: {}
        actions:
          type: array
          items:
            type: string
        cost:
          type: number
          format: double
        timestamp:
          $ref: "#/components/schemas/Instant"
        hmac:
          type: string
        agentSignature:
          type: string
    AuditExportEntry:
      type: object
      properties:
        conversationId:
          type: string
        agentId:
          type: string
        taskType:
          type: string
        durationMs:
          type: integer
          format: int64
        llmDetail:
          type: object
          additionalProperties: {}
        timestamp:
          $ref: "#/components/schemas/Instant"
    BatchRequestBuildingInstruction:
      type: object
      properties:
        pathToTargetArray:
          type: string
        iterationObjectName:
          type: string
        templateFilterExpression:
          type: string
        executeCallsSequentially:
          type: boolean
    Capability:
      type: object
      properties:
        skill:
          type: string
        attributes:
          type: object
          additionalProperties:
            type: string
        confidence:
          type: string
    CapabilityMatch:
      type: object
      properties:
        agentId:
          type: string
        skill:
          type: string
        confidence:
          type: string
        attributes:
          type: object
          additionalProperties:
            type: string
    CascadeStep:
      type: object
      properties:
        type:
          type: string
        parameters:
          type: object
          additionalProperties:
            type: string
        confidenceThreshold:
          type: number
          format: double
        timeoutMs:
          type: integer
          format: int64
    ChannelConnector:
      type: object
      properties:
        type:
          type: string
          format: uri
        config:
          type: object
          additionalProperties:
            type: string
    ConfigValue:
      type: object
      properties:
        displayName:
          type: string
        fieldType:
          $ref: "#/components/schemas/FieldType"
        isOptional:
          type: boolean
        defaultValue: {}
    Context:
      type: object
      properties:
        type:
          $ref: "#/components/schemas/ContextType"
        value: {}
    ContextScope:
      type: string
      enum:
      - NONE
      - FULL
      - LAST_PHASE
      - ANONYMOUS
      - OWN_FEEDBACK
    ContextType:
      type: string
      enum:
      - string
      - expressions
      - object
      - array
    ConversationDescriptor:
      type: object
      properties:
        resource:
          type: string
          format: uri
        createdBy:
          type: string
          format: uri
        createdOn:
          $ref: "#/components/schemas/Date"
        lastModifiedBy:
          type: string
          format: uri
        lastModifiedOn:
          $ref: "#/components/schemas/Date"
        deleted:
          type: boolean
        agentName:
          type: string
        userId:
          type: string
        agentResource:
          type: string
          format: uri
        viewState:
          $ref: "#/components/schemas/ViewState"
        conversationStepSize:
          type: integer
          format: int32
        createdByUserName:
          type: string
        environment:
          $ref: "#/components/schemas/Environment"
        conversationState:
          $ref: "#/components/schemas/ConversationState"
    ConversationExportEntry:
      type: object
      properties:
        conversationId:
          type: string
        agentId:
          type: string
        agentVersion:
          type: integer
          format: int32
        state:
          $ref: "#/components/schemas/ConversationState"
        outputs:
          type: array
          items:
            $ref: "#/components/schemas/ConversationOutput"
    ConversationMemorySnapshot:
      type: object
      properties:
        agentId:
          type: string
        agentVersion:
          type: integer
          format: int32
        userId:
          type: string
        environment:
          $ref: "#/components/schemas/Environment"
        conversationState:
          $ref: "#/components/schemas/ConversationState"
        conversationOutputs:
          type: array
          items:
            $ref: "#/components/schemas/ConversationOutput"
        conversationProperties:
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Property"
        conversationSteps:
          type: array
          items:
            $ref: "#/components/schemas/ConversationStepSnapshot"
        redoCache:
          type: array
          items:
            $ref: "#/components/schemas/ConversationStepSnapshot"
        _id:
          type: string
    ConversationOutput:
      type: object
    ConversationState:
      type: string
      enum:
      - READY
      - IN_PROGRESS
      - ENDED
      - EXECUTION_INTERRUPTED
      - ERROR
    ConversationStatus:
      type: object
      properties:
        conversationId:
          type: string
        agentId:
          type: string
        agentVersion:
          type: integer
          format: int32
        conversationState:
          $ref: "#/components/schemas/ConversationState"
        lastInteraction:
          $ref: "#/components/schemas/Date"
    ConversationStepData:
      type: object
      properties:
        key:
          type: string
        value: {}
        timestamp:
          $ref: "#/components/schemas/Date"
        originWorkflowId:
          type: string
    ConversationStepSnapshot:
      type: object
      properties:
        packages:
          type: array
          items:
            $ref: "#/components/schemas/WorkflowRunSnapshot"
        workflows:
          type: array
          items:
            $ref: "#/components/schemas/WorkflowRunSnapshot"
    ConversationSummaryConfig:
      type: object
      properties:
        enabled:
          type: boolean
        llmProvider:
          type: string
        llmModel:
          type: string
        maxSummaryTokens:
          type: integer
          format: int32
        excludePropertiesFromSummary:
          type: boolean
        recentWindowSteps:
          type: integer
          format: int32
        maxRecallTurns:
          type: integer
          format: int32
        summarizationPrompt:
          type: string
    CoordinatorStatus:
      type: object
      properties:
        coordinatorType:
          type: string
        connected:
          type: boolean
        connectionStatus:
          type: string
        activeConversations:
          type: integer
          format: int32
        totalProcessed:
          type: integer
          format: int64
        totalDeadLettered:
          type: integer
          format: int64
        queueDepths:
          type: object
          additionalProperties:
            type: integer
            format: int32
    CreateApiAgentRequest:
      type: object
      required:
      - agentName
      - systemPrompt
      - openApiSpec
      properties:
        agentName:
          type: string
        systemPrompt:
          type: string
        openApiSpec:
          type: string
        provider:
          type: string
        model:
          type: string
        apiKey:
          type: string
        apiBaseUrl:
          type: string
        apiAuth:
          type: string
        endpoints:
          type: string
        enableQuickReplies:
          type: boolean
        enableSentimentAnalysis:
          type: boolean
        deploy:
          type: boolean
        environment:
          type: string
    Date:
      type: string
      format: date
      examples:
      - 2022-03-10
    DeadLetterEntry:
      type: object
      properties:
        id:
          type: string
        conversationId:
          type: string
        error:
          type: string
        timestamp:
          type: integer
          format: int64
        payload:
          type: string
    DeploymentInfo:
      type: object
      properties:
        agentId:
          type: string
        agentVersion:
          type: integer
          format: int32
        environment:
          $ref: "#/components/schemas/Environment"
        deploymentStatus:
          $ref: "#/components/schemas/DeploymentStatus"
    DeploymentStatus:
      type: string
      enum:
      - deployed
      - undeployed
    DictionaryConfiguration:
      type: object
      properties:
        lang:
          type: string
        words:
          type: array
          items:
            $ref: "#/components/schemas/WordConfiguration"
        regExs:
          type: array
          items:
            $ref: "#/components/schemas/RegExConfiguration"
        phrases:
          type: array
          items:
            $ref: "#/components/schemas/PhraseConfiguration"
    DiffAction:
      type: string
      enum:
      - CREATE
      - UPDATE
      - SKIP
      - CONFLICT
    DiscussRequest:
      type: object
      properties:
        question:
          type: string
        userId:
          type: string
    DiscussionPhase:
      type: object
      properties:
        name:
          type: string
        type:
          $ref: "#/components/schemas/PhaseType"
        participants:
          type: string
        turnOrder:
          $ref: "#/components/schemas/TurnOrder"
        contextScope:
          $ref: "#/components/schemas/ContextScope"
        targetEachPeer:
          type: boolean
        inputTemplate:
          type: string
        repeats:
          type: integer
          format: int32
    DiscussionStyle:
      type: string
      enum:
      - ROUND_TABLE
      - PEER_REVIEW
      - DEVIL_ADVOCATE
      - DELPHI
      - DEBATE
      - CUSTOM
    DocumentDescriptor:
      type: object
      properties:
        resource:
          type: string
          format: uri
        createdBy:
          type: string
          format: uri
        createdOn:
          $ref: "#/components/schemas/Date"
        lastModifiedBy:
          type: string
          format: uri
        lastModifiedOn:
          $ref: "#/components/schemas/Date"
        deleted:
          type: boolean
        name:
          type: string
        description:
          type: string
        originId:
          type: string
    DreamConfig:
      type: object
      properties:
        enabled:
          type: boolean
        schedule:
          type: string
        detectContradictions:
          type: boolean
        contradictionResolution:
          type: string
        pruneStaleAfterDays:
          type: integer
          format: int32
        summarizeInteractions:
          type: boolean
        llmProvider:
          type: string
        llmModel:
          type: string
        maxCostPerRun:
          type: number
          format: double
        batchSize:
          type: integer
          format: int32
        maxUsersPerRun:
          type: integer
          format: int32
    Environment:
      type: string
      enum:
      - production
      - test
    ExportPreview:
      type: object
      properties:
        agentId:
          type: string
        agentName:
          type: string
        agentVersion:
          type: integer
          format: int32
        resources:
          type: array
          items:
            $ref: "#/components/schemas/ExportableResource"
    ExportableResource:
      type: object
      properties:
        resourceId:
          type: string
        resourceVersion:
          type: integer
          format: int32
        resourceType:
          type: string
        name:
          type: string
        parentWorkflowId:
          type: string
        workflowIndex:
          type: integer
          format: int32
        required:
          type: boolean
    ExtensionDescriptor:
      type: object
      properties:
        type:
          type: string
        displayName:
          type: string
        configs:
          type: object
          additionalProperties:
            $ref: "#/components/schemas/ConfigValue"
        extensions:
          type: object
          additionalProperties:
            type: array
            items:
              $ref: "#/components/schemas/ExtensionDescriptor"
    FieldType:
      type: string
      enum:
      - INT
      - DOUBLE
      - STRING
      - BOOLEAN
      - ARRAY
      - URI
    FireStatus:
      type: string
      enum:
      - PENDING
      - CLAIMED
      - EXECUTING
      - COMPLETED
      - FAILED
      - DEAD_LETTERED
    GdprDeletionResult:
      type: object
      properties:
        userId:
          type: string
        memoriesDeleted:
          type: integer
          format: int64
        conversationsDeleted:
          type: integer
          format: int64
        conversationMappingsDeleted:
          type: integer
          format: int64
        logsPseudonymized:
          type: integer
          format: int64
        auditEntriesPseudonymized:
          type: integer
          format: int64
        completedAt:
          $ref: "#/components/schemas/Instant"
    GroupConversation:
      type: object
      properties:
        id:
          type: string
        groupId:
          type: string
        userId:
          type: string
        state:
          $ref: "#/components/schemas/GroupConversationState"
        originalQuestion:
          type: string
        transcript:
          type: array
          items:
            $ref: "#/components/schemas/TranscriptEntry"
        memberConversationIds:
          type: object
          additionalProperties:
            type: string
        currentPhaseIndex:
          type: integer
          format: int32
        currentPhaseName:
          type: string
        synthesizedAnswer:
          type: string
        depth:
          type: integer
          format: int32
        created:
          $ref: "#/components/schemas/Instant"
        lastModified:
          $ref: "#/components/schemas/Instant"
    GroupConversationState:
      type: string
      enum:
      - CREATED
      - IN_PROGRESS
      - SYNTHESIZING
      - COMPLETED
      - FAILED
    GroupMember:
      type: object
      properties:
        agentId:
          type: string
        displayName:
          type: string
        speakingOrder:
          type: integer
          format: int32
        role:
          type: string
        memberType:
          $ref: "#/components/schemas/MemberType"
    Guardrails:
      type: object
      properties:
        maxKeyLength:
          type: integer
          format: int32
        maxValueLength:
          type: integer
          format: int32
        maxWritesPerTurn:
          type: integer
          format: int32
        allowedCategories:
          type: array
          items:
            type: string
    HttpCodeValidator:
      type: object
      properties:
        runOnHttpCode:
          type: array
          items:
            type: integer
            format: int32
        skipOnHttpCode:
          type: array
          items:
            type: integer
            format: int32
    HttpPostResponse:
      type: object
      properties:
        propertyInstructions:
          type: array
          items:
            $ref: "#/components/schemas/PropertyInstruction"
        outputBuildInstructions:
          type: array
          items:
            $ref: "#/components/schemas/OutputBuildingInstruction"
        qrBuildInstructions:
          type: array
          items:
            $ref: "#/components/schemas/QuickRepliesBuildingInstruction"
        retryApiCallInstruction:
          $ref: "#/components/schemas/RetryApiCallInstruction"
    HttpPreRequest:
      type: object
      properties:
        propertyInstructions:
          type: array
          items:
            $ref: "#/components/schemas/PropertyInstruction"
        batchRequests:
          $ref: "#/components/schemas/BatchRequestBuildingInstruction"
        delayBeforeExecutingInMillis:
          type: integer
          format: int32
    ImportPreview:
      type: object
      properties:
        sourceAgentId:
          type: string
        sourceAgentName:
          type: string
        targetAgentId:
          type: string
        targetAgentName:
          type: string
        resources:
          type: array
          items:
            $ref: "#/components/schemas/ResourceDiff"
    InputData:
      type: object
      properties:
        input:
          type: string
        context:
          type: object
          additionalProperties:
            $ref: "#/components/schemas/Context"
    InstanceInfo:
      type: object
      properties:
        instanceId:
          type: string
    Instant:
      type: string
      format: date-time
      examples:
      - 2022-03-10T16:15:50Z
    JsonRpcRequest:
      type: object
      properties:
        jsonrpc:
          type: string
        method:
          type: string
        params:
          type: object
          additionalProperties: {}
        id: {}
    KekRotationRequest:
      type: object
      properties:
        oldMasterKey:
          type: string
        newMasterKey:
          type: string
    KnowledgeBaseReference:
      type: object
      properties:
        name:
          type: string
        maxResults:
          type: integer
          format: int32
        minScore:
          type: number
          format: double
        injectionStrategy:
          type: string
        contextTemplate:
          type: string
    LlmConfiguration:
      type: object
      properties:
        tasks:
          type: array
          items:
            $ref: "#/components/schemas/Task"
    LogEntry:
      type: object
      properties:
        timestamp:
          type: integer
          format: int64
        level:
          type: string
        loggerName:
          type: string
        message:
          type: string
        environment:
          type: string
        agentId:
          type: string
        agentVersion:
          type: integer
          format: int32
        conversationId:
          type: string
        userId:
          type: string
        instanceId:
          type: string
    MatchingInfo:
      type: object
      properties:
        valuePath:
          type: string
        contains:
          type: string
        equals:
          type: string
        trueIfNoMatch:
          type: boolean
    McpCall:
      type: object
      properties:
        name:
          type: string
        description:
          type: string
        actions:
          type: array
          items:
            type: string
        toolName:
          type: string
        toolArguments:
          type: object
          additionalProperties: {}
        preRequest:
          $ref: "#/components/schemas/PreRequest"
        saveResponse:
          type: boolean
        responseObjectName:
          type: string
        postResponse:
          $ref: "#/components/schemas/PostResponse"
    McpCallsConfiguration:
      type: object
      properties:
        mcpServerUrl:
          type: string
        name:
          type: string
        transport:
          type: string
        apiKey:
          type: string
        timeoutMs:
          type: integer
          format: int64
        toolsWhitelist:
          type: array
          items:
            type: string
        toolsBlacklist:
          type: array
          items:
            type: string
        mcpCalls:
          type: array
          items:
            $ref: "#/components/schemas/McpCall"
    MemberFailurePolicy:
      type: string
      enum:
      - SKIP
      - RETRY
      - ABORT
    MemberType:
      type: string
      enum:
      - AGENT
      - GROUP
    MemberUnavailablePolicy:
      type: string
      enum:
      - SKIP
      - FAIL
    MemoryPolicy:
      type: object
      properties:
        strictWriteDiscipline:
          $ref: "#/components/schemas/StrictWriteDiscipline"
        effectivelyEnabled:
          type: boolean
    ModelCascadeConfig:
      type: object
      properties:
        enabled:
          type: boolean
        strategy:
          type: string
        evaluationStrategy:
          type: string
        enableInAgentMode:
          type: boolean
        steps:
          type: array
          items:
            $ref: "#/components/schemas/CascadeStep"
    OrphanInfo:
      type: object
      properties:
        resourceUri:
          type: string
          format: uri
        type:
          type: string
        name:
          type: string
        deleted:
          type: boolean
    OrphanReport:
      type: object
      properties:
        totalOrphans:
          type: integer
          format: int32
        deletedCount:
          type: integer
          format: int32
        orphans:
          type: array
          items:
            $ref: "#/components/schemas/OrphanInfo"
    Output:
      type: object
      properties:
        valueAlternatives:
          type: array
          items:
            $ref: "#/components/schemas/OutputItem"
    OutputBuildingInstruction:
      type: object
      properties:
        pathToTargetArray:
          type: string
        iterationObjectName:
          type: string
        templateFilterExpression:
          type: string
        outputType:
          type: string
        outputValue:
          type: string
        httpCodeValidator:
          $ref: "#/components/schemas/HttpCodeValidator"
    OutputConfiguration:
      type: object
      properties:
        action:
          type: string
        timesOccurred:
          type: integer
          format: int32
        outputs:
          type: array
          items:
            $ref: "#/components/schemas/Output"
        quickReplies:
          type: array
          items:
            $ref: "#/components/schemas/QuickReply"
    OutputConfigurationSet:
      type: object
      properties:
        lang:
          type: string
        outputSet:
          type: array
          items:
            $ref: "#/components/schemas/OutputConfiguration"
    OutputItem:
      type: object
